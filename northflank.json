{
  "apiVersion": "v1.2",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "project",
          "spec": {
            "name": "learning",
            "color": "#57637A",
            "networking": {
              "tailscale": {
                "authKeyTags": [],
                "enabled": false
              },
              "allowedIngressProjects": []
            },
            "region": "europe-west-zurich"
          }
        },
        {
          "kind": "SecretGroup",
          "spec": {
            "type": "secret",
            "secretType": "environment-arguments",
            "priority": 10,
            "secrets": {
              "variables": {
                "MW_ADMIN_USER": "WikiSysop",
                "MW_ADMIN_PASS": "F9nASCt69VX3Ai3BrliNtyPjrUj94RdE",
                "MW_SERVER_URL": "",
                "MW_SITENAME": "CC Public Wiki"
              },
              "files": {},
              "dockerSecretMounts": {}
            },
            "addonDependencies": [
              {
                "addonId": "${refs.database.id}",
                "keys": [
                  {
                    "keyName": "DATABASE",
                    "aliases": [
                      "MARIADB_DATABASE"
                    ]
                  },
                  {
                    "keyName": "PASSWORD",
                    "aliases": [
                      "MARIADB_ROOT_PASSWORD"
                    ]
                  },
                  {
                    "keyName": "USERNAME",
                    "aliases": [
                      "MARIADB_USER"
                    ]
                  },
                  {
                    "keyName": "HOST",
                    "aliases": [
                      "MW_DB_HOST"
                    ]
                  },
                  {
                    "keyName": "PORT",
                    "aliases": [
                      "MW_DB_PORT"
                    ]
                  }
                ]
              }
            ],
            "externalAddonDependencies": [],
            "name": "secrets",
            "restrictions": {
              "restricted": false,
              "nfObjects": [],
              "tags": []
            }
          },
          "ref": "secrets"
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "parallel",
            "context": {
              "projectId": "${refs.project.id}"
            },
            "steps": [
              {
                "kind": "Workflow",
                "spec": {
                  "type": "sequential",
                  "steps": [
                    {
                      "kind": "CombinedService",
                      "spec": {
                        "deployment": {
                          "instances": 1,
                          "storage": {
                            "ephemeralStorage": {
                              "storageSize": 1024
                            },
                            "shmSize": 64
                          },
                          "docker": {
                            "configType": "default"
                          }
                        },
                        "loadBalancing": {
                          "mode": "leastConnection"
                        },
                        "buildSettings": {
                          "storage": {
                            "ephemeralStorage": {
                              "storageSize": 16384
                            }
                          },
                          "dockerfile": {
                            "buildEngine": "buildkit",
                            "dockerWorkDir": "/",
                            "dockerFilePath": "/Dockerfile",
                            "buildkit": {
                              "useCache": false,
                              "cacheStorageSize": 16384
                            }
                          }
                        },
                        "billing": {
                          "deploymentPlan": "nf-compute-10",
                          "buildPlan": "nf-compute-400-16"
                        },
                        "runtimeEnvironment": {
                          "MARIADB_DATABASE": "my_wiki"
                        },
                        "runtimeFiles": {},
                        "buildArguments": {},
                        "buildFiles": {},
                        "dockerSecretMounts": {},
                        "infrastructure": {
                          "architecture": "x86"
                        },
                        "name": "Public Wiki",
                        "vcsData": {
                          "projectType": "github",
                          "accountLogin": "creativecommons",
                          "projectUrl": "https://github.com/creativecommons/public-wiki",
                          "projectBranch": "main"
                        },
                        "ports": [
                          {
                            "internalPort": 80,
                            "protocol": "HTTP",
                            "name": "p01",
                            "public": true,
                            "domains": [],
                            "security": {
                              "policies": [],
                              "credentials": [],
                              "securePathConfiguration": {
                                "rules": []
                              }
                            },
                            "disableNfDomain": false
                          }
                        ],
                        "disabledCI": false,
                        "buildConfiguration": {
                          "pathIgnoreRules": [],
                          "isAllowList": false,
                          "ciIgnoreFlagsEnabled": false
                        }
                      },
                      "ref": "public-wiki"
                    }
                  ]
                }
              },
              {
                "kind": "Addon",
                "spec": {
                  "infrastructure": {
                    "architecture": "x86"
                  },
                  "externalAccessEnabled": false,
                  "type": "mysql",
                  "billing": {
                    "replicas": 2,
                    "storage": 20480,
                    "storageClass": "nvme",
                    "deploymentPlan": "nf-compute-200-4"
                  },
                  "tlsEnabled": true,
                  "version": "latest",
                  "name": "database",
                  "customCredentials": {
                    "dbName": "my_wiki"
                  }
                },
                "ref": "database",
                "options": {
                  "upgradeOnVersionMismatch": true
                }
              }
            ]
          }
        }
      ]
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "gitops": {
    "repoUrl": "https://github.com/creativecommons/northflank-learning",
    "vcsService": "github",
    "accountLogin": "creativecommons",
    "branch": "main",
    "filePath": "/northflank.json"
  },
  "$schema": "https://api.northflank.com/v1/schemas/template"
}