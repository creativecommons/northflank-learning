{
  "apiVersion": "v1.2",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "project",
          "spec": {
            "name": "public-wiki",
            "color": "#57637A",
            "networking": {
              "tailscale": {
                "authKeyTags": [],
                "enabled": false
              },
              "allowedIngressProjects": []
            },
            "region": "europe-west-zurich"
          }
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "sequential",
            "steps": [
              {
                "kind": "Addon",
                "spec": {
                  "infrastructure": {
                    "architecture": "x86"
                  },
                  "externalAccessEnabled": false,
                  "type": "mysql",
                  "billing": {
                    "replicas": 1,
                    "storage": 20480,
                    "storageClass": "nvme",
                    "deploymentPlan": "nf-compute-200-4"
                  },
                  "tlsEnabled": false,
                  "version": "latest",
                  "name": "database",
                  "customCredentials": {
                    "dbName": "my_wiki"
                  }
                },
                "ref": "database",
                "options": {
                  "upgradeOnVersionMismatch": false
                }
              },
              {
                "kind": "SecretGroup",
                "spec": {
                  "type": "secret",
                  "secretType": "environment-arguments",
                  "priority": 10,
                  "secrets": {
                    "variables": {
                      "MW_ADMIN_USER": "WikiSysop",
                      "MW_ADMIN_PASS": "[POPULATE VALUE IN OVERRIDE]",
                      "MW_SERVER_URL": "https://wiki-dev.creativecommons.org",
                      "MW_SITENAME": "CC Public Wiki"
                    },
                    "files": {},
                    "dockerSecretMounts": {}
                  },
                  "addonDependencies": [
                    {
                      "addonId": "${refs.database.id}",
                      "keys": [
                        {
                          "keyName": "DATABASE",
                          "aliases": [
                            "MARIADB_DATABASE"
                          ]
                        },
                        {
                          "keyName": "PASSWORD",
                          "aliases": [
                            "MARIADB_ROOT_PASSWORD"
                          ]
                        },
                        {
                          "keyName": "USERNAME",
                          "aliases": [
                            "MARIADB_USER"
                          ]
                        },
                        {
                          "keyName": "HOST",
                          "aliases": [
                            "MW_DB_HOST"
                          ]
                        },
                        {
                          "keyName": "PORT",
                          "aliases": [
                            "MW_DB_PORT"
                          ]
                        }
                      ]
                    }
                  ],
                  "externalAddonDependencies": [],
                  "name": "secrets",
                  "restrictions": {
                    "restricted": false,
                    "nfObjects": [],
                    "tags": []
                  }
                },
                "ref": "secrets"
              },
              {
                "kind": "CombinedService",
                "spec": {
                  "deployment": {
                    "instances": 1,
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 1024
                      },
                      "shmSize": 64
                    },
                    "docker": {
                      "configType": "default"
                    }
                  },
                  "loadBalancing": {
                    "mode": "leastConnection"
                  },
                  "buildSettings": {
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 16384
                      }
                    },
                    "dockerfile": {
                      "buildEngine": "buildkit",
                      "dockerWorkDir": "/",
                      "dockerFilePath": "/Dockerfile",
                      "buildkit": {
                        "useCache": false,
                        "cacheStorageSize": 16384
                      }
                    }
                  },
                  "billing": {
                    "deploymentPlan": "nf-compute-10",
                    "buildPlan": "nf-compute-400-16"
                  },
                  "runtimeEnvironment": {},
                  "runtimeFiles": {},
                  "buildArguments": {},
                  "buildFiles": {},
                  "dockerSecretMounts": {},
                  "infrastructure": {
                    "architecture": "x86"
                  },
                  "name": "service-public-wiki",
                  "vcsData": {
                    "projectType": "github",
                    "accountLogin": "creativecommons",
                    "projectUrl": "https://github.com/creativecommons/public-wiki",
                    "projectBranch": "main"
                  },
                  "ports": [
                    {
                      "internalPort": 80,
                      "protocol": "HTTP/2",
                      "name": "p01",
                      "public": true,
                      "domains": [],
                      "security": {
                        "policies": [],
                        "credentials": [],
                        "securePathConfiguration": {
                          "rules": []
                        }
                      },
                      "disableNfDomain": false
                    }
                  ],
                  "buildConfiguration": {
                    "pathIgnoreRules": [
                      "config/",
                      "Dockerfile"
                    ],
                    "isAllowList": true
                  },
                  "disabledCI": false,
                  "healthChecks": [
                    {
                      "type": "livenessProbe",
                      "protocol": "TCP",
                      "initialDelaySeconds": 5,
                      "periodSeconds": 60,
                      "timeoutSeconds": 10,
                      "failureThreshold": 3,
                      "port": 80
                    }
                  ]
                },
                "ref": "public-wiki"
              },
              {
                "kind": "Volume",
                "spec": {
                  "spec": {
                    "accessMode": "ReadWriteOnce",
                    "storageSize": 10240,
                    "storageClassName": "nvme"
                  },
                  "mounts": [
                    {
                      "containerMountPath": "/var/lib/mediawiki/assets",
                      "volumeMountPath": "assets"
                    },
                    {
                      "containerMountPath": "/etc/mediawiki",
                      "volumeMountPath": "etc"
                    },
                    {
                      "containerMountPath": "/var/lib/mediawiki/images",
                      "volumeMountPath": "images"
                    }
                  ],
                  "name": "volume-mediawiki",
                  "attachedObjects": [
                    {
                      "id": "${refs.public-wiki.id}",
                      "type": "service"
                    }
                  ]
                },
                "ref": "mediawiki"
              }
            ],
            "context": {
              "projectId": "${refs.project.id}"
            }
          }
        }
      ]
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "forbid"
  },
  "gitops": {
    "repoUrl": "https://github.com/creativecommons/northflank-learning",
    "vcsService": "github",
    "accountLogin": "creativecommons",
    "branch": "main",
    "filePath": "/public-wiki/northflank.json"
  },
  "$schema": "https://api.northflank.com/v1/schemas/template"
}